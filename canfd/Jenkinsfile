pipeline {
    agent { label 'vcs' }

    environment {
        VERIFY_HOME    = "${WORKSPACE}"
        VCS_HOME       = "/tools/synopsys/vcs/vcs-mx-2023.12"
        VERDI_HOME     = "/tools/synopsys/verdi/verdi-2023.12"
        LM_LICENSE_FILE = "27000@license-server"
        STAGE           = "${STAGE_NAME}"
    }

    parameters {
        choice(name: 'REGRESSION_GROUP',
               choices: ['all', 'T1', 'T2', 'T3', 'T4', 'T5', 'T6', 'T7'],
               description: 'Test group to run')
        booleanParam(name: 'ENABLE_COVERAGE', defaultValue: true,
                     description: 'Enable coverage collection')
        booleanParam(name: 'ENABLE_GLS', defaultValue: false,
                     description: 'Enable gate-level simulation')
        string(name: 'SEED', defaultValue: '',
               description: 'Fixed random seed (empty = random)')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Branch: ${env.BRANCH_NAME}"
                echo "Commit: ${env.GIT_COMMIT.take(8)}"
            }
        }

        stage('Environment Setup') {
            steps {
                sh '''
                    echo "VCS_HOME: ${VCS_HOME}"
                    echo "VERDI_HOME: ${VERDI_HOME}"
                    which vcs || echo "VCS not in PATH"
                    vcs -version || true
                '''
            }
        }

        stage('Regression') {
            steps {
                script {
                    def cmd = "python3 run/regression.py --run ${params.REGRESSION_GROUP}"
                    if (params.ENABLE_COVERAGE) {
                        cmd += " --cov"
                    }
                    if (params.ENABLE_GLS) {
                        cmd += " --gls"
                    }
                    if (params.SEED) {
                        cmd += " --seed ${params.SEED}"
                    }
                    cmd += " --parallel 8"

                    sh "cd ${WORKSPACE} && ${cmd}"
                }
            }
        }

        stage('Coverage Merge') {
            when { expression { params.ENABLE_COVERAGE } }
            steps {
                sh "cd ${WORKSPACE} && python3 run/regression.py --covmerge"
            }
        }

        stage('Publish Results') {
            steps {
                script {
                    // Publish JSON report
                    archiveArtifacts artifacts: 'results/regression_report.json', fingerprint: true

                    // Publish simulation logs for failed tests
                    def report = readJSON file: 'results/regression_report.json'
                    def passRate = report.meta.pass_rate
                    def total = report.meta.total
                    def passed = report.meta.passed
                    def failed = report.meta.failed

                    currentBuild.description = "Pass: ${passed}/${total} (${passRate}%)"

                    if (failed > 0) {
                        echo "FAILED TESTS:"
                        report.details.findAll { it.status != 'PASS' }.each {
                            echo "  [${it.status}] ${it.group}/${it.test} seed=${it.seed}"
                        }
                    }
                }
            }
        }

        stage('Coverage Report') {
            when { expression { params.ENABLE_COVERAGE } }
            steps {
                // Publish coverage HTML - adjust for your CI tool
                publishHTML(target: [
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: 'coverage/coverage_result',
                    reportFiles: '*.html',
                    reportName: 'CANFD Coverage Report'
                ])
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            emailext(
                subject: "[CANFD CI] PASS - ${env.BRANCH_NAME} (${currentBuild.description})",
                body: "Regression passed.\n\n${env.BUILD_URL}\n\n${currentBuild.description}",
                to: 'verification-team@company.com'
            )
        }
        failure {
            emailext(
                subject: "[CANFD CI] FAIL - ${env.BRANCH_NAME}",
                body: "Regression failed.\n\n${env.BUILD_URL}\n\nCheck logs for details.",
                to: 'verification-team@company.com'
            )
        }
    }
}
